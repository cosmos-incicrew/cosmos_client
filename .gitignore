# Flutter/Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
# pubspec.lock 은 앱 레포에서는 커밋합니다 (팀 간 의존성 버전 고정).

# 로컬 전용 (커밋 금지 — 각자 PC의 SDK 경로 등)
android/local.properties
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh

# IDE
.idea/
.vscode/*
# 팀 공용 실행 설정만 공유한다 (웹 3000 포트 고정 + dart-define 주입).
!.vscode/launch.json
*.iml

# 민감 정보 (dart-define / env)
*.env
env.local.dart
# 실제 키가 든 dart-define 파일. example 만 커밋한다.
dart_defines/*.json
!dart_defines/*.example.json

# OS
.DS_Store
Thumbs.db

# 로컬 도구 설정 (개인 환경)
.claude/
.vercel/
.omc

# 로컬 환경 값 (--dart-define-from-file 용) — 커밋 금지
env.local.json
